APP_NAME = Secure API Gateway(APIGATE)
ENV = dev
HOST = 0.0.0.0
PORT = 8443
LOG_LEVEL = info

RATE_LIMIT_BACKEND = redis
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

AUTH_REQUIRED = true
OAUTH_JWT_SECRET = change_this_in_production
OAUTH_ISSUER = secure-gateway
OAUTH_AUDIENCE = secure-gateway-clients
OAUTH2_TOKEN_URL=/auth/token
OAUTH2_JWT_ALGORITHM=HS256
OAUTH2_LEEWAY_SECONDS=30

UPSTREAM_BASE_URL=http://localhost:9000
MOCK_UPSTREAM=true

OPENAPI_SPEC_PATH=specs/gateway.openapi.yaml
OPENAPI_VALIDATE_REQUESTS=true

OTEL_SERVICE_NAME=secure-api-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_LOGS_ENABLED=true
OTEL_TRACES_ENABLED=true

DASHBOARD_ENABLED = true
DASHBOARD_API_KEY = change_this_in_production